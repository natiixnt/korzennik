# Korzennik configuration
# Copy this to .env and fill in your values

# FamilySearch API key (get one at https://developers.familysearch.org/)
KORZENNIK_FAMILYSEARCH_APP_KEY=

# Database URL (default: SQLite)
KORZENNIK_DATABASE_URL=sqlite+aiosqlite:///./korzennik.db

# Geneteka scraping delay in seconds (be respectful)
KORZENNIK_GENETEKA_DELAY_SECONDS=1.5

# Debug mode
KORZENNIK_DEBUG=false
